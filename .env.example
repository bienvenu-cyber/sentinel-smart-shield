# ===========================================
# Configuration du système de surveillance
# Copier vers .env : cp .env.example .env
# ===========================================

# --- Frigate ---
FRIGATE_RTSP_USER=admin
# Pour EZVIZ : c'est le CODE DE VÉRIFICATION (6 lettres MAJ) imprimé sur la caméra
FRIGATE_RTSP_PASSWORD=REMPLACER_PAR_MOT_DE_PASSE_CAMERA_2
FRIGATE_URL=http://frigate:5000
# URL publique via Cloudflare Tunnel (rempli après setup-tunnel.sh)
FRIGATE_PUBLIC_URL=https://frigate.tondomaine.com

# --- Caméra EZVIZ CS-C6N ---
# Trouver l'IP : ./scan-network.sh  (cherche "Hangzhou Ezviz")
# Tester le flux : ./test-rtsp.sh rtsp://admin:CODE@IP:554/Streaming/Channels/101
CAM_EZVIZ_IP=192.168.10.206
CAM_EZVIZ_PORT=554
CAM_EZVIZ_PATH=/Streaming/Channels/101

# --- Caméra EZVIZ #2 (CS-C6N) ---
# Identifiée via le DHCP du routeur (nom BD5913478, MAC 34:C6:DD = Hangzhou Ezviz).
# Chaque caméra EZVIZ a SON propre code de vérification (imprimé sur l'étiquette).
CAM_EZVIZ2_IP=192.168.10.122
CAM_EZVIZ2_PORT=554
CAM_EZVIZ2_PATH=/Streaming/Channels/101
# Code de vérification cam 2 (6 lettres MAJ imprimées sur la caméra)
FRIGATE_RTSP_PASSWORD_CAM2=REMPLACER_PAR_MOT_DE_PASSE_CAMERA_1

# --- MQTT ---
MQTT_HOST=mosquitto
MQTT_PORT=1883

# --- WapiWay API (https://api.wapiway.tech) ---
WAPIWAY_API_KEY=sk_live_xxxxxxxxxxxx
# Numéros SANS le +, séparés par des virgules
WAPIWAY_PHONE_NUMBERS=229XXXXXXXX,33612345678
# Session WapiWay (optionnel — auto-sélection si omis)
WAPIWAY_SESSION_ID=

# --- Cloudflare Tunnel ---
CLOUDFLARE_TUNNEL_TOKEN=

# --- Filtrage des alertes ---
# Score minimum de confiance IA pour déclencher une alerte (0.0 à 1.0)
# 0.70 = bon compromis pour caméras intérieures (EZVIZ CS-C6N en rôtisserie).
# Augmenter à 0.80 si trop de faux positifs ; baisser à 0.60 si trop de ratés.
MIN_SCORE=0.70
TRACKED_LABELS=person,car,truck,motorcycle
COOLDOWN_SECONDS=120

# --- Logique intelligente Tolaro Global (rôtisserie) ---
# ⚙️ TROIS RÈGLES ACTIVES (priorité décroissante, demandées par le DG mai 2026) :
#
#   1) MODE NUIT (NIGHT_HOUR_START → NIGHT_HOUR_END) :
#      Toute personne détectée sur N'IMPORTE QUELLE caméra = alerte
#      immédiate (intrusion potentielle, locaux fermés).
#
#   2) CAMÉRA(S) D'ENTRÉE (ENTRANCE_CAMERAS) :
#      Sur ces caméras, CHAQUE passage de personne (entrée ET sortie)
#      déclenche une alerte avec photo + heure exacte. Permet de
#      tracer les allées et venues à l'entrée principale (rôtisserie).
#
#   3) AUTRES CAMÉRAS EN JOURNÉE :
#      Règle "reprise d'activité" — alerte uniquement si mouvement
#      après INACTIVITY_THRESHOLD_SECONDS sans aucune détection.

# --- Règle 1 : mode nuit ---
# Plage horaire considérée comme "nuit" (locaux fermés).
# Si NIGHT_HOUR_START > NIGHT_HOUR_END, la plage traverse minuit
# (ex: 20 → 6 = de 20h00 à 05h59).
NIGHT_HOUR_START=20
NIGHT_HOUR_END=6
# Anti-rafale nuit : délai mini entre deux alertes nuit sur la même caméra.
NIGHT_COOLDOWN_SECONDS=60

# --- Règle 2 : caméra(s) d'entrée principale ---
# Liste séparée par des virgules des noms Frigate des caméras qui
# doivent alerter à CHAQUE passage de personne (entrée + sortie).
# Exemple actuel : "ezviz" (la cam EZVIZ posée sur l'entrée du
# rôtissage). À mettre à jour quand la 2e caméra sera installée.
ENTRANCE_CAMERAS=ezviz
# Anti-doublon : on ne renvoie pas deux alertes "entrée" coup sur coup
# pour la même personne qui reste dans le champ. 30 s = bon compromis.
ENTRANCE_COOLDOWN_SECONDS=30

# --- Règle 3 : reprise d'activité (autres cams en journée) ---
# 3600 = 1 h pile (valeur demandée par le DG).
INACTIVITY_THRESHOLD_SECONDS=3600
# Anti-rafale : délai minimum entre deux alertes "reprise d'activité"
# sur la même caméra (sinon chaque mouvement consécutif rerelance).
REACTIVATION_COOLDOWN_SECONDS=300

# --- Plan B (désactivé dans le code, conservé pour bascule rapide) ---
# Heures ouvrées (format 24h) : alertes filtrées par zone
# Hors heures ouvrées : TOUTE détection = alerte (mode renforcé)
BUSINESS_HOUR_START=6
BUSINESS_HOUR_END=19
# Jours ouvrés : 0=lundi ... 6=dimanche  (donc 0,1,2,3,4,5 = lun-sam)
BUSINESS_DAYS=0,1,2,3,4,5
# Cooldown plus court la nuit (réactivité maximale)
COOLDOWN_SECONDS_NIGHT=30
# Zones où une personne est INTERDITE même en journée (alerte immédiate)
RESTRICTED_ZONES=zone_restreinte
# Fuseau horaire (Bénin = Africa/Porto-Novo, UTC+1)
TZ=Africa/Porto-Novo

# --- Type de média envoyé par alerte ---
# image  → snapshot Frigate (rapide, ~50 Ko)
# video  → clip Frigate (plus lourd, mais plus parlant)
# both   → snapshot immédiat + clip dès qu'il est dispo
#
# ⚙️ Réglage actif (demandé par le DG, mai 2026) : "both"
#   → On envoie d'abord la photo (réactivité < 5 s) PUIS un petit
#     clip vidéo de quelques secondes dès que Frigate l'a finalisé.
#     Indispensable pour les alertes "reprise d'activité après 1 h
#     d'inactivité" : la vidéo permet de juger l'intention.
ALERT_MEDIA_TYPE=both
# Délai (secondes) à attendre avant de récupérer le clip vidéo.
# Frigate finalise le clip ~10 s après la fin de l'événement ;
# 15 s est un bon compromis (clip court mais complet).
VIDEO_WAIT_SECONDS=15
