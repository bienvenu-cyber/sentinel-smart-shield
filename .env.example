# ===========================================
# Configuration du système de surveillance
# Copier vers .env : cp .env.example .env
# ===========================================

# --- Frigate ---
FRIGATE_RTSP_USER=admin
# Pour EZVIZ : c'est le CODE DE VÉRIFICATION (6 lettres MAJ) imprimé sur la caméra
FRIGATE_RTSP_PASSWORD=ZWVCHO
FRIGATE_URL=http://frigate:5000
# URL publique via Cloudflare Tunnel (rempli après setup-tunnel.sh)
FRIGATE_PUBLIC_URL=https://frigate.tondomaine.com

# --- Caméra EZVIZ CS-C6N ---
# Trouver l'IP : ./scan-network.sh  (cherche "Hangzhou Ezviz")
# Tester le flux : ./test-rtsp.sh rtsp://admin:CODE@IP:554/Streaming/Channels/101
CAM_EZVIZ_IP=192.168.0.105
CAM_EZVIZ_PORT=554
CAM_EZVIZ_PATH=/Streaming/Channels/101

# --- MQTT ---
MQTT_HOST=mosquitto
MQTT_PORT=1883

# --- WapiWay API (https://api.wapiway.tech) ---
WAPIWAY_API_KEY=sk_live_xxxxxxxxxxxx
# Numéros SANS le +, séparés par des virgules
WAPIWAY_PHONE_NUMBERS=229XXXXXXXX,33612345678
# Session WapiWay (optionnel — auto-sélection si omis)
WAPIWAY_SESSION_ID=

# --- Cloudflare Tunnel ---
CLOUDFLARE_TUNNEL_TOKEN=

# --- Filtrage des alertes ---
MIN_SCORE=0.75
TRACKED_LABELS=person,car
COOLDOWN_SECONDS=60

# --- Type de média envoyé par alerte ---
# image  → snapshot Frigate (rapide, ~50 Ko)
# video  → clip Frigate (plus lourd, mais plus parlant)
# both   → snapshot immédiat + clip dès qu'il est dispo
ALERT_MEDIA_TYPE=image
# Délai (secondes) à attendre avant de récupérer le clip vidéo
# (Frigate finalise le clip après la fin de l'événement)
VIDEO_WAIT_SECONDS=15
