# ===========================================
# Configuration du système de surveillance
# Copier ce fichier vers .env et remplir les valeurs
# ===========================================

# --- Frigate ---
FRIGATE_RTSP_USER=admin
FRIGATE_RTSP_PASSWORD=motdepasse_camera
FRIGATE_URL=http://frigate:5000
# URL publique de Frigate (nécessaire pour que WapiWay accède aux snapshots)
# Ex: https://frigate.mondomaine.com ou un tunnel ngrok/cloudflare
FRIGATE_PUBLIC_URL=https://frigate.mondomaine.com

# --- MQTT ---
MQTT_HOST=mosquitto
MQTT_PORT=1883

# --- WapiWay API (https://api.wapiway.tech) ---
WAPIWAY_API_KEY=sk_live_xxxxxxxxxxxx
# Numéros destinataires SANS le +, séparés par des virgules
WAPIWAY_PHONE_NUMBERS=229XXXXXXXX,33612345678
# ID de session WapiWay (optionnel — si omis, la 1ère session connectée est utilisée)
WAPIWAY_SESSION_ID=

# --- Filtrage des alertes ---
MIN_SCORE=0.75
TRACKED_LABELS=person,car
COOLDOWN_SECONDS=60
